<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FleetManager.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FleetManager.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FleetManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        x:CompileBindings="False"
        Title="FleetManager">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Orientation="Horizontal">
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Lista Pojazdów" FontWeight="Bold" Margin="20" FontSize="30" />
            <ListBox ItemsSource="{Binding Vehicles}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <views:VehicleItemView />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Dodaj Nowy Pojazd" FontWeight="Bold" Margin="20" FontSize="30" />
            <TextBox Watermark="Nazwa Pojazdu" Text="{Binding NewName}" Margin="0, 0, 0, 20" />
            <TextBox Watermark="Numer Rejestracyjny" Text="{Binding NewRegistrationNumber}" Margin="0, 0, 0, 20" />
            <Button Content="Dodaj Pojazd" Command="{Binding AddCommand}" />
        </StackPanel>
    </StackPanel>

</Window>
